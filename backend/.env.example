# Bind address for the FastAPI process. Caddy proxies the public TLS port to this.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8080

# Shared secret the web app sends in the X-Scanner-Token header.
# Must match HETZNER_SCANNER_AUTH_TOKEN in the Vercel project.
HETZNER_SCANNER_AUTH_TOKEN=change-me

# Shared secret this worker sends in the x-hetzner-webhook-secret header
# when posting results back. Must match HETZNER_WEBHOOK_SECRET in Vercel.
HETZNER_WEBHOOK_SECRET=change-me

# Web app callback URL. Production: https://vulnscanners.com/api/scans/webhook
VERCEL_WEBHOOK_URL=https://vulnscanners.com/api/scans/webhook

# GCP / GCS
GCP_PROJECT_ID=hosted-scanners
GCP_BUCKET_NAME=hosted-scanners-reports
# Base64-encoded service account JSON. Required for signed URL generation.
GCP_SERVICE_ACCOUNT_KEY=

# Concurrency: number of simultaneous scans the worker runs.
SCAN_CONCURRENCY=2

# Per-scan wall-clock timeout in seconds.
SCAN_TIMEOUT_SECONDS=1800

# Block scans against private/internal/loopback ranges (RFC1918, link-local, etc.)
BLOCK_PRIVATE_TARGETS=true

# Optional: ZAP daemon HTTP API. If empty, ZAP is run via `zap.sh` CLI.
ZAP_API_URL=
ZAP_API_KEY=

# Optional: directory containing nuclei templates. If empty, the bundled set is used.
NUCLEI_TEMPLATES_DIR=

# Log level
LOG_LEVEL=INFO
