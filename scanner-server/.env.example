# Network
HOST=0.0.0.0
PORT=8080

# Public hostname served by Caddy (DNS A record must point to this VPS)
SCANNER_HOSTNAME=scanner.vulnscanners.com
CADDY_ACME_EMAIL=admin@vulnscanners.com

# Shared secrets (generate: openssl rand -hex 32) — must match Vercel env vars
HETZNER_SCANNER_AUTH_TOKEN=replace-me
HETZNER_WEBHOOK_SECRET=replace-me

# Where to POST scan results back to
VERCEL_WEBHOOK_URL=https://vulnscanners.com/api/scans/webhook

# GCP storage for scan outputs
GCP_BUCKET_NAME=hosted-scanners-reports
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-key.json
GCP_SIGNED_URL_TTL_SECONDS=604800

# Worker sizing
MAX_CONCURRENT_SCANS=2
SCAN_TIMEOUT_SECONDS=1800

# OWASP ZAP (docker-compose service)
ZAP_API_URL=http://zap:8090
ZAP_API_KEY=replace-me

# Nuclei templates (leave blank to use baked-in default path)
NUCLEI_TEMPLATES_DIR=

# Safety switch — keep off in production
ALLOW_PRIVATE_TARGETS=false
