# /etc/vulnscanners/backend.env
# Environment variables for the VulnScanners scanner worker.
#
# SECURITY RULES:
#   - This file must NEVER be committed to git.
#   - Permissions: chmod 600 /etc/vulnscanners/backend.env
#   - Ownership:   chown scanner:scanner /etc/vulnscanners/backend.env
#   - Only the 'scanner' user and root should be able to read this file.
#
# To populate:
#   sudo cp ops/env/backend.env.example /etc/vulnscanners/backend.env
#   sudo chown scanner:scanner /etc/vulnscanners/backend.env
#   sudo chmod 600 /etc/vulnscanners/backend.env
#   sudo nano /etc/vulnscanners/backend.env   # fill in real values
#
# ---------------------------------------------------------------------------
# Scanner ↔ Web App shared secret
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Must match GCP_WEBHOOK_SECRET set in Vercel production env.
# ---------------------------------------------------------------------------
GCP_WEBHOOK_SECRET=REPLACE_WITH_GENERATED_SECRET

# ---------------------------------------------------------------------------
# Vercel / Next.js webhook callback URL
# The scanner POSTs results back to this endpoint.
# ---------------------------------------------------------------------------
VERCEL_WEBHOOK_URL=https://vulnscanners.com/api/scans/webhook

# ---------------------------------------------------------------------------
# Firebase Admin credentials (for Firestore writes from the worker)
# ---------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=REPLACE_WITH_PROJECT_ID
FIREBASE_ADMIN_CLIENT_EMAIL=REPLACE_WITH_SERVICE_ACCOUNT_EMAIL
# Newlines in the private key must be preserved as literal \n (single-line):
FIREBASE_ADMIN_PRIVATE_KEY=REPLACE_WITH_PRIVATE_KEY_ESCAPED

# ---------------------------------------------------------------------------
# GCS / Cloud Storage (for scan result uploads)
# ---------------------------------------------------------------------------
GCS_BUCKET_NAME=REPLACE_WITH_BUCKET_NAME
# Optional: path to GCP service account JSON (alternative to inline key above)
# GOOGLE_APPLICATION_CREDENTIALS=/etc/vulnscanners/gcp-sa.json

# ---------------------------------------------------------------------------
# Redis (Celery broker + result backend)
# Default: local Redis, no password — change if you add Redis auth
# ---------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# ---------------------------------------------------------------------------
# FastAPI application settings
# ---------------------------------------------------------------------------
APP_ENV=production
LOG_LEVEL=info
# Comma-separated list of allowed scanner types
ALLOWED_SCAN_TYPES=nmap,nuclei,zap

# ---------------------------------------------------------------------------
# Optional: Sentry DSN for error tracking
# ---------------------------------------------------------------------------
# SENTRY_DSN=https://REPLACE@oXXXXX.ingest.sentry.io/XXXXXX
