# Worker environment variables.
# Deployed to the Hetzner VM at /etc/vulnscanners/backend.env (root-only).
# The systemd unit reads this file via EnvironmentFile=.

# Shared secret used to authenticate the Vercel app → worker /scan POSTs
# AND the worker → Vercel webhook POSTs back. Same secret as the
# HETZNER_WEBHOOK_SECRET / HETZNER_SCANNER_AUTH_TOKEN vars in Vercel.
GCP_WEBHOOK_SECRET=replace-me

# Webhook the worker POSTs results to once a scan finishes.
VERCEL_WEBHOOK_URL=https://vulnscanners.com/api/scans/webhook

# Number of concurrent scan workers (default 2). Each can run one
# subprocess at a time, so set higher only if the VM has the cores.
SCAN_WORKERS=2

# Hard kill-switch for any single scan, in seconds (default 1800).
# subprocess.run uses this as its timeout; a scan that exceeds it is
# terminated and posted back with status=failed.
SCAN_TIMEOUT_SECONDS=1800
