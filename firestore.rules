rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read/write their own user doc and subcollections
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /completedScans/{scanId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // All writes go through /api/scans (Admin SDK) — deny client writes.
        allow write: if false;
      }

      // Saved scan targets. All mutations go through /api/targets routes
      // which use the Admin SDK, so client-side writes are denied.
      match /targets/{targetId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // Recurring scan schedules. Reads/writes go through /api/scheduled-scans
      // (Admin SDK); client reads own, client writes denied.
      match /scheduledScans/{scheduleId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }
  }
}
