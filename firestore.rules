rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read/write their own user doc and subcollections
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /completedScans/{scanId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // All writes go through /api/scans (Admin SDK) — deny client writes.
        allow write: if false;
      }

      // Saved scan targets. All mutations go through /api/targets routes
      // which use the Admin SDK, so client-side writes are denied.
      match /targets/{targetId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // Allow users to read their own global scans (used by fallback queries)
    match /scans/{scanId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      // Prevent client-side writes to global scans (server/admin only)
      allow write: if false;
    }
  }
}
